# =============================================================================
# DuckPools Off-Chain Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# =============================================================================

# ── Ergo Node ─────────────────────────────────────────────────────────────────
NODE_URL=http://localhost:9052
ERGO_API_KEY=

# ── Contract (coinflip_v2.es, deployed) ──────────────────────────────────────
# Must match smart-contracts/coinflip_deployed.json exactly.
CONTRACT_ERGO_

# ── House Wallet ─────────────────────────────────────────────────────────────
# House Ergo address (testnet P2PK)
HOUSE_ADDRESS=
# Wallet password for signing reveal transactions
WALLET_PASS=

# ── Backend API (for bet history sync) ───────────────────────────────────────
# The bot posts settled bet results here so the backend can update history.
BACKEND_API_URL=http://localhost:8000

# ── Polling ──────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=5
REVEAL_DELAY_BLOCKS=2

# ── Heartbeat ────────────────────────────────────────────────────────────────
HEARTBEAT_FILE=/tmp/off-chain-bot-heartbeat.txt
HEARTBEAT_INTERVAL_SECONDS=30

# ── Health Server ────────────────────────────────────────────────────────────
HEALTH_SERVER_PORT=8001

# ── House Edge ───────────────────────────────────────────────────────────────
# Must match coinflip_v2.es: winPayout = betAmount * 97 / 50
HOUSE_EDGE_BPS=300
