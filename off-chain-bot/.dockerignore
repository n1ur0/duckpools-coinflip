# =============================================================================#
# DuckPools Coinflip - Off-chain Bot .dockerignore
# =============================================================================#
# This file tells Docker which files to exclude when building the bot image.
# This reduces build time and image size.
# =============================================================================#

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Virtual environments
venv/
env/
ENV/
.env.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Documentation
docs/
README.md
*.md

# Git
.git/
.gitignore

# Docker
Dockerfile
.dockerignore

# Temporary files
*.tmp
*.temp
.cache/

# Development specific
development/
tests/
integration_tests/

# Other project directories
backend/
frontend/
scripts/
tools/
docs/

# Node.js (if any frontend components)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local configuration
.env
.env.local
.env.*.local

# Docker compose files
docker-compose*.yml

# Data files
data/
*.json
*.csv
*.xlsx
# Keep sample data if needed
!sample_data/

# Model files (if any ML components)
models/
*.pkl
*.h5
*.pt
*.onnx

# Temporary bot state
state/
bot_state.json
*.state