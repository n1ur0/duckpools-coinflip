{
  "name": "@duckpools/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for DuckPools Coinflip protocol on Ergo blockchain",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test dist/test/*.test.js",
    "test:watch": "tsc --watch & node --test --watch dist/test/*.test.js",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ergo",
    "blockchain",
    "duckpools",
    "coinflip",
    "gambling",
    "sdk",
    "typescript"
  ],
  "author": "DuckPools Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/duckpools/coinflip-sdk"
  },
  "dependencies": {
    "buffer": "^6.0.3"
  },
  "peerDependencies": {
    "@fleet-sdk/core": "^0.11.0"
  },
  "peerDependenciesMeta": {
    "@fleet-sdk/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
