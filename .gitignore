*.db
*.sqlite
*.sqlite3
*.sql.gz
pgdata/
data/
db-backups/
*.dump
*.bak
*.backup

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
