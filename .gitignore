# ==============================================================================
# DuckPools Coinflip - Comprehensive .gitignore
# ==============================================================================

# -----------------------------------------------------------------------------
# Environment Variables & Secrets (NEVER COMMIT THESE)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env
secrets/
*.key
*.pem
*.p12
*.pfx
wallet-seed.txt
wallet-mnemonic.txt
api_keys.txt

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
server.log
pm2-logs/

# -----------------------------------------------------------------------------
