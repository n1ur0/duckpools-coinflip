.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Vim
*.swp
*.swo
*.swn
*~
vim-tmp/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
junit.xml
test-results.xml
.playwright-cache/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
target/
build/
*.tgz
*.tar.gz

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# OS / Temporary Files
#-------------
*.tmp
*.temp
tmp/
temp/
*.cache
.cache/

# -----------------------------------------------------------------------------
# Documentation (Drafts)
#-------------
docs/draft/
docs/WIP/
*_DRAFT.md
*_TODO.md
~$*.doc* # Office temp files

# -----------------------------------------------------------------------------
# CI/CD
#-------------
.github/workflows/*.local.yml
.github/deploy-keys/
deploy/
secrets/

# -----------------------------------------------------------------------------
# Ergo / Blockchain Specific
#-------------
ergo-testnet/data/
ergo-mainnet/data/
*.ergo
wallet.json
*.wallet
blockchain-data/

# -----------------------------------------------------------------------------
# Paperclip (Project Management)
#-------------
.paperclip/
paperclip-config.local.json

# -----------------------------------------------------------------------------
# Backup Files
#-------------
*.backup
*.old
*.orig
*.bak
backup/
backups/

# -----------------------------------------------------------------------------
# PM2
#-------------
.pm2/
ecosystem.config.local.js

# -----------------------------------------------------------------------------
# Git Worktrees (local only, never committed)
#-------------
worktrees/

# -----------------------------------------------------------------------------
# Misc
#-------------
.DS_Store
*.pid
*.seed
*.pid.lock
.env.test
.heroku/
.vercel
.now
.netlify

# -----------------------------------------------------------------------------
# Development Only (Keep in development branch, exclude in main)
#-------------
