# =============================================================================
# DuckPools Coinflip - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
#
# Quick Start with Docker:
#   cp .env.example .env
#   # Edit .env with your configuration
#   docker compose build
#   docker compose up -d
#
# =============================================================================

# =============================================================================
# Node Configuration
# =============================================================================

# Ergo node URL (host.docker.internal allows Docker containers to reach host)
NODE_URL=http://host.docker.internal:9052

# Testnet explorer API URL
EXPLORER_URL=http://localhost:9052

# =============================================================================
# Wallet Configuration
# =============================================================================

# House wallet address (testnet address)
# Example: 3WybUXMjv722ebGYh69bQGQMsb7yb3LJ1EWqPp22UDH2RFNKgcRi
# IMPORTANT: Replace with your actual testnet wallet address
HOUSE_ADDRESS=

# Wallet password for signing transactions
# SECURITY: Never commit this value!
# Set your actual Ergo wallet password here
WALLET_PASS=

# =============================================================================
# Game Assets
# =============================================================================

# Game NFT ID (set after deployment)
COINFLIP_NFT_ID=

# v2 Contract ErgoTrees (trustless on-chain verification)
V2_PENDING_BET_SCRIPT=
V2_GAME_STATE_SCRIPT=

# Legacy v1 PendingBet ErgoTree (for backward compatibility)
PENDING_BET_ERGOTREE=

# Optional: Token ID for alternative betting token (e.g., USDT, SigUSD)
# Leave empty for ERG-only betting
BETTING_TOKEN_ID=

# ==============================================================================
# API Configuration
# ==============================================================================

# SEC-1: Separate API keys for node access and bot endpoint authentication.
# These MUST be different credentials to prevent a compromised bot endpoint
# from gaining full node access (wallet operations, box spending, etc.).

# API Key for Ergo Node Wallet Operations
# CRITICAL: This must match the authKey in your ergo.conf file
#
# For local node with wallet access:
# 1. Check your ergo.conf file (usually in ~/.ergo/ or node directory)
# 2. Look for: scorex.restApi.apiKeyHash
# 3. The NODE_API_KEY value is the plain text that hashes to that value
#
# Default (if not changed in ergo.conf):
#   apiKeyHash: blake2b256("hello") = 324dcf027dd4a30a932c441f365a25e86b173defa4b8e58948253471b81b72cf
#   NODE_API_KEY=***
NODE_API_KEY=***

# API Key for bot endpoint authentication (separate from node key!)
# This authenticates requests to the house bot's processing endpoints.
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_API_KEY=

# =============================================================================
# Backend Configuration
# =============================================================================

# Backend port
BACKEND_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level (DEBUG, INFO, WARNING, ERROR)
BACKEND_LOG_LEVEL=INFO

# =============================================================================
# Frontend Configuration
# =============================================================================

# Frontend port
FRONTEND_PORT=3000

# HMR (Hot Module Replacement) port
FRONTEND_HMR_PORT=24678

# Network (testnet or mainnet)
VITE_NETWORK=testnet

# Backend API URL (from browser perspective)
VITE_API_ENDPOINT=http://localhost:8000

# Explorer URL
VITE_EXPLORER_URL=https://testnet.ergoplatform.com

# Ergo node URL (from browser perspective)
VITE_NODE_URL=http://localhost:9052

# Minimum bet amount (in ERG)
VITE_MIN_BET=0.001

# Maximum bet percentage of pool TVL
VITE_MAX_BET_PERCENTAGE=10

# =============================================================================
# Bot Configuration
# =============================================================================

# Enable/disable automated betting processing
ENABLE_BOT=true

# Enable/disable setup mode (creates initial game boxes)
# Set to true when running deploy_coinflip.py
SETUP_MODE=false

# Enable/disable automatic liquidity management
AUTO_LIQUIDITY=false

# Enable/disable Discord notifications
DISCORD_NOTIFICATIONS=false

# Discord webhook URL for notifications (if enabled above)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =============================================================================
# Oracle Configuration
# =============================================================================

# Primary oracle endpoint URL (Ergo Oracle Pool)
ORACLE_PRIMARY_URL=https://api.oraclepool.xyz

# Backup oracle endpoint URLs (comma-separated, optional)
# Example: https://backup1.oraclepool.com,https://backup2.oraclepool.com
ORACLE_BACKUP_URLS=

# Time in seconds before considering a feed stale (default: 300 = 5 minutes)
ORACLE_STALE_THRESHOLD_SECONDS=300

# Health check interval in seconds (default: 30)
ORACLE_HEALTH_CHECK_INTERVAL_SECONDS=30

# =============================================================================
# Development/Testing
# =============================================================================

# Enable debug logging (more verbose output)
DEBUG_MODE=false

# Report wallet balance on startup
REPORT_BALANCE=true

# Dry run mode (skip actual transaction submission)
# Set to true to test without spending testnet ERG
DRY_RUN=false

# =============================================================================
# Security Notes
# =============================================================================
#
# ⚠️ CRITICAL SECURITY WARNING ⚠️
#
# 1. NEVER commit .env to version control
# 2. NEVER share WALLET_PASS or wallet mnemonics
# 3. NEVER share private keys or seed phrases
# 4. VERIFY HOUSE_ADDRESS is a testnet address (starts with 3W... or 9h...)
# 5. USE TESTNET first - never test on mainnet with real funds
# 6. After deployment, update COINFLIP_NFT_ID with the minted NFT ID
#
# =============================================================================
