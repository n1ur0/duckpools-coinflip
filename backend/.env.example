# =============================================================================
# DuckPools CoinFlip Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
#
# The backend also inherits from the root .env file when running via Docker Compose.
# Only backend-specific overrides go here.
# =============================================================================

# ---------------------------------------------------------------------------
# Ergo Node Configuration
# ---------------------------------------------------------------------------
NODE_URL=http://localhost:9052
# API key for Ergo node (must match apiKeyHash in ergo.conf)
NODE_API_KEY=your_node_api_key_here

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# For local development with SQLite:
DATABASE_URL=sqlite:///./duckpools.db
# For Docker/production with PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://duckpools:duckpools_dev@localhost:5432/duckpools

# ---------------------------------------------------------------------------
# Game Configuration
# ---------------------------------------------------------------------------
# House edge in basis points (300 = 3%)
HOUSE_EDGE_BPS=300

# Maximum bet in nanoERG (100,000 ERG)
MAX_BET_NANOERG=100000000000000

# ---------------------------------------------------------------------------
# Wallet Configuration
# ---------------------------------------------------------------------------
HOUSE_ADDRESS=your_testnet_house_address_here
WALLET_PASS=your_wallet_password_here

# ---------------------------------------------------------------------------
# Contract Configuration (set after deployment)
# ---------------------------------------------------------------------------
COINFLIP_NFT_ID=
PENDING_BET_ERGOTREE=

# ---------------------------------------------------------------------------
# API Rate Limiting
# ---------------------------------------------------------------------------
# Maximum requests per minute per IP address
API_RATE_LIMIT_PER_IP=60
# Maximum requests per minute per wallet address
API_RATE_LIMIT_PER_ADDRESS=120

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Secret key for JWT tokens (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# WebSocket authentication (MAT-396/5.1)
# HMAC secret for signing WebSocket auth tokens
WS_TOKEN_SECRET=
